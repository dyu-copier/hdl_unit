.ONESHELL:
SHELL=/bin/bash
BO_DIR ?= bo
TOP_FILE = $({{ip_name|capitalize}}_ROOT)/verilog/mk{{ip_name|capitalize}}.v

build_opts= -elab -p $(BSC_PATH) +RTS -K128M -RTS -u -verilog -remove-dollar -steps 10000000 -vdir $({{ip_name|capitalize}}_ROOT)/verilog -bdir $(BO_DIR) -info-dir $(BO_DIR) -aggressive-conditions -no-warn-action-shadowing -no-show-timestamps -check-assert -show-range-conflict -keep-fires

build: folders rdl
	$(MAKE) build_bsv 
rdl:
	$(MAKE) -C ../systemrdl
folders:
	mkdir -p $(BO_DIR)
	mkdir -p $({{ip_name|capitalize}}_ROOT)/verilog/

build_bsv: copy_files
	set -e; $(BLUESPEC_HOME)/bin/bsc $(build_opts) {{ip_name}}.bsv
	grep -q dumpfile $(TOP_FILE) || sed -i 's/endmodule/initial begin\n  $$dumpfile("decode.vcd");\n  $$dumpvars;\nend\nendmodule/' $(TOP_FILE)

copy_files:
	bsc_v="$(BLUESPEC_HOME)/lib/Verilog"; \
	if [ -d "$$bsc_v" ]; then \
	    cp -p "$$bsc_v"/FIFO*.v     "$({{ip_name|capitalize}}_ROOT)/verilog/" 2>/dev/null || true; \
	    cp -p "$$bsc_v"/FIFOL*.v    "$({{ip_name|capitalize}}_ROOT)/verilog/" 2>/dev/null || true; \
	    cp -p "$$bsc_v"/SizedFIFO.v "$({{ip_name|capitalize}}_ROOT)/verilog/" 2>/dev/null || true; \
	    cp -p "$$bsc_v"/BRAM*.v     "$({{ip_name|capitalize}}_ROOT)/verilog/" 2>/dev/null || true; \
	    echo "BSC Verilog models copied from $$bsc_v"; \
	else \
	    echo "Warning: no lib/Verilog dir found under $(BLUESPEC_HOME)"; \
	fi
