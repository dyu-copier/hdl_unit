
import Semi_FIFOF :: *;
import AXI4_Types :: *;
import APB_Types  :: *;
import {{ip_name|capitalize}}_Reg_csr::*;

// AXI ID width = 4: keeps awid/arid/bid/rid in the generated Verilog port list
// so cocotbext-axi's AxiRam / AxiBus can bind them at sim setup. Width can be
// any integer >= 1; 4 is the AMBA-idiomatic default. See bsv_axi/docs/axi_fixes.md.
interface {{ip_name|capitalize}}_Ifc;
  interface AXI4_Master_IFC#(4,32,32,0) axi4;
  interface APB_Slave_IFC#(32,32,0) apb;
endinterface

(*synthesize*)
module mk{{ip_name|capitalize}}({{ip_name|capitalize}}_Ifc);

  ConfigCSR_{{ip_name|capitalize}}_Reg csr <- mkConfigCSR_{{ip_name|capitalize}}_Reg();
  AXI4_Master_Xactor_IFC#(4,32,32,0) xactor <- mkAXI4_Master_Xactor;
  APB_Slave_Xactor_IFC#(32,32,0) apbif <- mkAPB_Slave_Xactor;

  Wire#(APB_request#(32,32,0)) wr_apb_req_first <- mkWire();
  rule apb_request_first;
    wr_apb_req_first <= apbif.fifo_side.o_request.first();
  endrule

  rule rl_csr_read if(!wr_apb_req_first.pwrite);
    let x = wr_apb_req_first;
    apbif.fifo_side.o_request.deq();
    let a = x.paddr;
    let rv <- csr.read(truncate(a));
    apbif.fifo_side.i_response.enq(
      APB_response{prdata:rv, pslverr:False, puser:0});
  endrule

  rule rl_csr_write_apb (apbif.fifo_side.o_request.notEmpty());
    let x = apbif.fifo_side.o_request.first();
    if(x.pwrite) begin
      apbif.fifo_side.o_request.deq();
      let a = x.paddr;
      let d = x.pwdata;
      let s = x.pstrb;
      csr.write(truncate(a), d, s);
      apbif.fifo_side.i_response.enq(APB_response{prdata:0, pslverr:False, puser:0});
    end
  endrule

  interface axi4 = xactor.axi_side;
  interface apb  = apbif.apb_side;
endmodule
