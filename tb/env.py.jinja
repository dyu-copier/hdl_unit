from {{ip_name|capitalize}}_Reg.reg_model.{{ip_name|capitalize}}_Reg import {{ip_name|capitalize}}_Reg_cls
from {{ip_name|capitalize}}_Reg.lib import AsyncCallbackSet


class Env:
    """Testbench environment for {{ip_name}}.

    Owns the DUT handle, the peakrdl-python register model, and the active
    config-bus interface (`self.ifc`). Wire `self.ifc` to a bus VIP exposing
    `async def read(addr)` / `async def write(addr, data)` (e.g. an APB
    master from cocotbext-apb) in `__init__` or `start()`.
    """

    def __init__(self, dut, timeout=None):
        self.dut = dut
        self.reg = {{ip_name|capitalize}}_Reg_cls(
            callbacks=AsyncCallbackSet(
                read_callback=self.regRead,
                write_callback=self.regWrite))
        self.ifc = None  # TODO: set this to the config-bus VIP (APB master)
        self.timeout = timeout
        self.init_config = None

    async def test(self, override_initialization=None):
        if override_initialization is not None:
            self.init_config = override_initialization
        self.start()
        self.initialize()
        await self.run()
        self.check()

    def start(self):
        pass

    def initialize(self):
        pass

    async def run(self):
        pass

    def check(self):
        pass

    async def regRead(self, addr: int, width: int, accesswidth: int):
        rv = await self.ifc.read(addr)
        value = int(rv)
        cocotb.log.info(f"RegRead addr={addr:#x} rdata={value:#x}")
        return value

    async def regWrite(self, addr: int, width: int, accesswidth: int, data: int):
        cocotb.log.info(f"RegWrite addr={addr:#x} data={data:#x}")
        return await self.ifc.write(addr, data)
