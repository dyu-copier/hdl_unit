IP_NAME    := {{ip_name}}
IP_ROOT    ?= $(shell git rev-parse --show-toplevel 2>/dev/null || pwd)
GIT_SHA    := $(shell git rev-parse --short HEAD 2>/dev/null || echo unknown)

OUTPUT_DIR := output
REPORTS_DIR := reports

SOURCES    := ai.md
REGISTER_DOC := registers.md
ifneq ($(wildcard $(REGISTER_DOC)),)
SOURCES    += $(REGISTER_DOC)
endif

PANDOC     ?= pandoc

.PHONY: doc clean dirs

doc: dirs
	$(PANDOC) \
	  --standalone \
	  --metadata title="$(IP_NAME) IP Reference Manual" \
	  --metadata date="$(GIT_SHA)" \
	  -o $(OUTPUT_DIR)/reference_manual.html \
	  $(SOURCES)
	@echo "Doc generated: $(OUTPUT_DIR)/reference_manual.html"

dirs:
	@mkdir -p $(OUTPUT_DIR) $(REPORTS_DIR)

clean:
	rm -rf $(OUTPUT_DIR) $(REPORTS_DIR)
