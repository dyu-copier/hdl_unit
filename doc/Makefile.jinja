title={{ip_name}} IP
client=TBD Client Name
docstatus=Working Document
document-sha=$(shell git rev-parse --short HEAD )
authoremail={{email}}
files=refman.md {{ip_name}}.md registers.md ai.md testplan.md
variables=-V title:"$(title)" -V client:"$(client)" -Vauthoremail:$(authoremail) -V document-sha:$(document-sha) -V status:"$(docstatus)"

# Pandoc assets are expected to be installed locally by the user:
#   $(HOME)/.pandoc/diagram.lua                    (pandoc-ext/diagram filter)
#   $(HOME)/.pandoc/template/dyu/refman.template   (document template)
PANDOC_FILTER=$(HOME)/.pandoc/diagram.lua
PANDOC_TEMPLATE=$(HOME)/.pandoc/template/dyu/refman.template

doc:
	@test -f $(PANDOC_FILTER) || { echo "ERROR: $(PANDOC_FILTER) not found — install the pandoc-ext/diagram Lua filter (see https://github.com/pandoc-ext/diagram)."; exit 1; }
	@test -f $(PANDOC_TEMPLATE) || { echo "ERROR: $(PANDOC_TEMPLATE) not found — install the dyu refman pandoc template."; exit 1; }
	pandoc --lua-filter=$(PANDOC_FILTER) $(variables) -o reference_manual.pdf -s --template=$(PANDOC_TEMPLATE) $(files)

clean:
	rm -f reference_manual.pdf
