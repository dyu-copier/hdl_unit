title={{ip_name}} IP
client=TBD Client Name
docstatus=Working Document
document-sha=$(shell git rev-parse --short HEAD 2>/dev/null || echo nogit)
authoremail={{email}}
files=refman.md {{ip_name}}.md registers.md ai.md testplan.md
variables=-V title:"$(title)" -V client:"$(client)" -Vauthoremail:$(authoremail) -V document-sha:$(document-sha) -V status:"$(docstatus)"

# Pandoc assets are expected to be installed locally by the user:
#   $(HOME)/.pandoc/diagram.lua                    (pandoc-ext/diagram filter)
#   $(HOME)/.pandoc/template/dyu/refman.template   (document template)
PANDOC_FILTER=$(HOME)/.pandoc/diagram.lua
PANDOC_TEMPLATE=$(HOME)/.pandoc/template/dyu/refman.template

# Full build (PDF, custom template + diagram filter) when the pandoc assets
# are installed; otherwise fall back to a plain standalone HTML build so the
# doc target still validates the markdown and produces an artifact (e.g. in
# CI containers without $(HOME)/.pandoc).
doc:
	@if [ -f $(PANDOC_FILTER) ] && [ -f $(PANDOC_TEMPLATE) ]; then \
	  pandoc --lua-filter=$(PANDOC_FILTER) $(variables) -o reference_manual.pdf -s --template=$(PANDOC_TEMPLATE) $(files); \
	else \
	  echo "WARN: $(PANDOC_FILTER) and/or $(PANDOC_TEMPLATE) not installed —"; \
	  echo "WARN: building plain standalone HTML instead of the templated PDF."; \
	  echo "WARN: install the pandoc-ext/diagram Lua filter (https://github.com/pandoc-ext/diagram)"; \
	  echo "WARN: and the dyu refman pandoc template for the full reference manual."; \
	  pandoc $(variables) -o reference_manual.html -s $(files); \
	fi

clean:
	rm -f reference_manual.pdf reference_manual.html
