[project]
name = "{{ip_name}}"
version = "0.1.0"
description = "{{ip_short_desc}}"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "cocotb>=2.0.0",
    "cocotb-coverage>=1.1.0",
    "cocotbext-axi>=0.1.24",
    "cocotbext-apb>=0.0.1",
    "peakrdl>=1.1.0",
    "peakrdl-bsv>=0.0.1",
    "peakrdl-cocotb-ralgen>=0.1.0",
    "peakrdl-html>=2.11.0",
    "peakrdl-markdown>=1.0.2",
    "peakrdl-python>=1.4.0",
    "peakrdl-regblock>=0.14.0",
    "pytest>=8.0.0",
]

# Note: simulation additionally needs a simulator on PATH (icarus verilog by
# default — `apt install iverilog` — or verilator), and the internal
# cocotbext.dyulib helpers where used by chip-level testbenches.
