# ============================================================================
# SDC Timing Constraints for {{ip_name}}
# Author: {{author}} <{{email}}>
# Description: {{ip_short_desc}}
#
# Target module: mk{{ip_name|capitalize}}
# Default clock: {{clock_freq_mhz}} MHz
#
# All I/O budgets, uncertainty and transition limits are computed as
# percentages of the clock period so they stay sane when clock_freq_mhz
# changes. They are generic placeholders — tighten per-interface once the
# spec provides real timing numbers.
# ============================================================================

# ----------------------------------------------------------------------
# Clock definition — 50% duty cycle on port CLK
# ----------------------------------------------------------------------
set CLK_PERIOD [expr { 1000.0 / {{clock_freq_mhz}} }]  ;# ns

create_clock -name clk -period $CLK_PERIOD \
    -waveform [list 0.0 [expr { $CLK_PERIOD / 2.0 }]] \
    [get_ports CLK]

# ----------------------------------------------------------------------
# Clock uncertainty / transition — 5% / 2% of period (jitter + skew)
# ----------------------------------------------------------------------
set_clock_uncertainty -setup [expr { $CLK_PERIOD * 0.05 }] [get_clocks clk]
set_clock_uncertainty -hold  0.05                          [get_clocks clk]
set_clock_transition  [expr { $CLK_PERIOD * 0.02 }]        [get_clocks clk]

# ----------------------------------------------------------------------
# Reset: asynchronous, active-low (project convention). The reset input
# is a false path — it must be synchronized inside the reset controller,
# not timed here.
# ----------------------------------------------------------------------
set_false_path -from [get_ports RST_N]

# ----------------------------------------------------------------------
# I/O timing budgets — 30% of period (max), small hold margin (min).
# CLK and RST_N are excluded from the I/O delay set rather than being
# assigned a zero delay.
# ----------------------------------------------------------------------
set IO_MAX [expr { $CLK_PERIOD * 0.30 }]
set IO_MIN [expr { $CLK_PERIOD * 0.05 }]

set data_inputs {}
foreach port [all_inputs] {
    set port_name [get_name $port]
    if {$port_name ne "CLK" && $port_name ne "RST_N"} {
        lappend data_inputs $port
    }
}
set data_outputs [all_outputs]

set_input_delay  -clock clk -max $IO_MAX $data_inputs
set_input_delay  -clock clk -min $IO_MIN $data_inputs
set_output_delay -clock clk -max $IO_MAX $data_outputs
set_output_delay -clock clk -min $IO_MIN $data_outputs

# ----------------------------------------------------------------------
# Environment: driving cell and output load (adjust for the PDK).
# Placeholders — uncomment and set real cells/caps for sign-off.
# ----------------------------------------------------------------------
# set_driving_cell -lib_cell <buffer_cell> $data_inputs
# set_load <cap_pf> $data_outputs

# ----------------------------------------------------------------------
# Max fanout / max transition — 10% of period slew budget
# ----------------------------------------------------------------------
set_max_fanout 20 [current_design]
set_max_transition [expr { $CLK_PERIOD * 0.10 }] [current_design]

