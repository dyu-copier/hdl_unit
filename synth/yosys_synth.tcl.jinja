# ============================================================================
# Yosys Synthesis Script for {{ip_name}} (Tcl mode — invoked via `yosys -c`)
# Author: {{author}} <{{email}}>
# Description: {{ip_short_desc}}
#
# In Tcl mode, yosys commands must be prefixed with `yosys` — plain names like
# `read_verilog` collide with Tcl builtins (e.g. `proc`) or are undefined.
# ============================================================================

# ----------------------------------------------------------------------
# Read design sources
# ----------------------------------------------------------------------
# Read all Verilog files from the verilog directory, excluding BRAM primitives
# (BSC library BRAMs use $fopen/sim pragmas that Yosys cannot parse in synthesis mode).
foreach vfile [glob -nocomplain ../verilog/*.v] {
    if {![string match */BRAM*.v $vfile]} {
        yosys read_verilog -sv $vfile
    }
}

# ----------------------------------------------------------------------
# Hierarchy check and elaboration
# ----------------------------------------------------------------------
yosys hierarchy -check -top mk{{ip_name|capitalize}}

# ----------------------------------------------------------------------
# High-level synthesis passes
# ----------------------------------------------------------------------
yosys proc
yosys flatten
yosys opt
yosys fsm
yosys opt
yosys memory
yosys opt

# ----------------------------------------------------------------------
# Technology mapping
# ----------------------------------------------------------------------
yosys techmap
yosys opt

# ----------------------------------------------------------------------
# Sequential + combinational technology mapping
# ----------------------------------------------------------------------
# dfflibmap maps DFFs to library cells (e.g. sky130_fd_sc_hd__dfxtp_1). Without
# it, ABC only maps combinational logic and the output netlist keeps behavioral
# `reg` + `always @(posedge)` blocks — which OpenSTA's parser rejects with
# "syntax error" on the `reg <output>;` line.
if {[info exists ::env(LIBERTY_FILE)] && $::env(LIBERTY_FILE) ne "" && [file exists $::env(LIBERTY_FILE)]} {
    yosys dfflibmap -liberty $::env(LIBERTY_FILE)
    yosys abc -liberty $::env(LIBERTY_FILE)
} else {
    yosys abc
}

# Final cleanup
yosys clean
yosys opt_clean -purge

# ----------------------------------------------------------------------
# Reports
# ----------------------------------------------------------------------
exec mkdir -p reports
yosys tee -o reports/mk{{ip_name|capitalize}}_area.rpt stat

if {[info exists ::env(LIBERTY_FILE)] && $::env(LIBERTY_FILE) ne "" && [file exists $::env(LIBERTY_FILE)]} {
    yosys tee -o reports/mk{{ip_name|capitalize}}_area_mapped.rpt stat -liberty $::env(LIBERTY_FILE)
}

# ----------------------------------------------------------------------
# Write synthesized netlist
# ----------------------------------------------------------------------
exec mkdir -p output
yosys write_verilog -noattr output/mk{{ip_name|capitalize}}_synth.v

yosys log "============================================"
yosys log " Synthesis of mk{{ip_name|capitalize}} complete"
yosys log " Netlist : output/mk{{ip_name|capitalize}}_synth.v"
yosys log " Reports : reports/"
yosys log "============================================"
