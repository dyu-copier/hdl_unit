# ============================================================================
# Synthesis Makefile for {{ip_name}}
# Author: {{author}} <{{email}}>
# Description: {{ip_short_desc}}
#
# Supported flows:
#   make synth_yosys  - Open-source synthesis with Yosys (default)
#   make synth_dc     - Synopsys Design Compiler (commercial)
#   make synth_genus  - Cadence Genus (commercial)
# ============================================================================

.ONESHELL:
SHELL=/bin/bash
.SHELLFLAGS := -o pipefail -ec

# ----------------------------------------------------------------------
# Directory and file configuration
# ----------------------------------------------------------------------
VERILOG_DIR   ?= $({{ip_name|upper}}_ROOT)/verilog
TOP_MODULE    ?= mk{{ip_name|capitalize}}
{% if liberty_file -%}
LIBERTY_FILE  ?= {{liberty_file}}
{%- else -%}
LIBERTY_FILE  ?= $(PDK_ROOT)/sky130A/libs.ref/sky130_fd_sc_hd/lib/sky130_fd_sc_hd__tt_025C_1v80.lib
{%- endif %}
SDC_FILE      ?= $({{ip_name|upper}}_ROOT)/constraints/{{ip_name}}.sdc

OUTPUT_DIR    := output
REPORTS_DIR   := reports
SCRIPTS_DIR   := $({{ip_name|upper}}_ROOT)/synth

# Tool paths (override as needed)
YOSYS         ?= yosys
DC_SHELL      ?= dc_shell
GENUS         ?= genus

# Gather all Verilog sources
VERILOG_SRCS  := $(wildcard $(VERILOG_DIR)/*.v)

# ============================================================================
# Default target
# ============================================================================
.PHONY: all synth_yosys synth_dc synth_genus clean dirs

all: synth_yosys

# ----------------------------------------------------------------------
# Create output directories
# ----------------------------------------------------------------------
dirs:
	@mkdir -p $(OUTPUT_DIR)
	@mkdir -p $(REPORTS_DIR)

# ============================================================================
# Yosys (open-source) synthesis flow
# ============================================================================
synth_yosys: dirs
	set -e; \
	echo "============================================"; \
	echo " Yosys Synthesis: $(TOP_MODULE)"; \
	echo "============================================"; \
	LIBERTY_FILE=$(LIBERTY_FILE) $(YOSYS) -c $(SCRIPTS_DIR)/yosys_synth.tcl 2>&1 | tee $(REPORTS_DIR)/yosys_synth.log; \
	test -f $(OUTPUT_DIR)/$(TOP_MODULE)_synth.v; \
	echo "Synthesis complete. Netlist: $(OUTPUT_DIR)/$(TOP_MODULE)_synth.v"; \
	echo "Reports written to: $(REPORTS_DIR)/"

# ============================================================================
# Synopsys Design Compiler (commercial) synthesis flow
# ============================================================================
synth_dc: dirs
	@echo "============================================"
	@echo " Design Compiler Synthesis: $(TOP_MODULE)"
	@echo "============================================"
	$(DC_SHELL) -topographical_mode \
	  -x " \
	    set TOP_MODULE $(TOP_MODULE); \
	    set VERILOG_DIR $(VERILOG_DIR); \
	    set LIBERTY_FILE $(LIBERTY_FILE); \
	    set SDC_FILE $(SDC_FILE); \
	    set OUTPUT_DIR $(OUTPUT_DIR); \
	    set REPORTS_DIR $(REPORTS_DIR); \
	    source $(SCRIPTS_DIR)/dc_synth.tcl; \
	    exit"
	@echo "DC synthesis complete."

# ============================================================================
# Cadence Genus (commercial) synthesis flow
# ============================================================================
synth_genus: dirs
	@echo "============================================"
	@echo " Genus Synthesis: $(TOP_MODULE)"
	@echo "============================================"
	$(GENUS) -batch \
	  -execute " \
	    set TOP_MODULE $(TOP_MODULE); \
	    set VERILOG_DIR $(VERILOG_DIR); \
	    set LIBERTY_FILE $(LIBERTY_FILE); \
	    set SDC_FILE $(SDC_FILE); \
	    set OUTPUT_DIR $(OUTPUT_DIR); \
	    set REPORTS_DIR $(REPORTS_DIR); \
	    source $(SCRIPTS_DIR)/genus_synth.tcl; \
	    exit"
	@echo "Genus synthesis complete."

# ============================================================================
# Clean
# ============================================================================
clean:
	rm -rf $(OUTPUT_DIR)
	rm -rf $(REPORTS_DIR)
	rm -rf *.log *.svf
	rm -rf yosys.history
	@echo "Synthesis outputs cleaned."
