# ==============================================================================
# OpenSTA power estimation script for {{ip_name}}
# Generated by Copier template
# ==============================================================================

set top_module  mk{{ip_name|capitalize}}
# Netlist and VCD injected by power/Makefile via env vars
set netlist     $::env(NETLIST)
set activity    $::env(ACTIVITY)
set sdc_file    ../constraints/{{ip_name}}.sdc
set lib_file    $::env(PDK_ROOT)/sky130A/libs.ref/sky130_fd_sc_hd/lib/sky130_fd_sc_hd__tt_025C_1v80.lib
set report_dir  reports

file mkdir $report_dir

# --- Read liberty timing library -------------------------------------------
puts "\n>>> Reading liberty: $lib_file"
read_liberty $lib_file

# --- Read synthesized Verilog netlist --------------------------------------
puts "\n>>> Reading netlist: $netlist"
read_verilog $netlist

# --- Link design -----------------------------------------------------------
puts "\n>>> Linking design: $top_module"
link_design $top_module

# --- Read SDC constraints --------------------------------------------------
puts "\n>>> Reading SDC: $sdc_file"
read_sdc $sdc_file

# --- Read switching activity (VCD) -----------------------------------------
puts "\n>>> Reading activity: $activity"
read_power_activities -scope ${top_module} \
    -vcd $activity

# --- Report power ----------------------------------------------------------
puts "\n>>> Reporting power"
report_power > $report_dir/${top_module}_power.rpt

puts "\n>>> Power analysis complete. Reports written to $report_dir/"
exit
