# ============================================================================
# Xilinx Design Constraints (XDC) — {{ip_name}}
# Author: {{author}} <{{email}}>
# Description: {{ip_short_desc}}
#
# This file contains pin assignments and timing constraints for FPGA
# prototyping of the {{ip_name|capitalize}} IP core.
#
# How to customize:
#   1. Update the FPGA_PART in the Makefile to match your board.
#   2. Uncomment and modify pin assignments below to match your board's
#      schematic (check the board reference manual for pin mappings).
#   3. Adjust the clock period if your board uses a different oscillator.
#   4. Add additional constraints for multi-clock domains as needed.
# ============================================================================

# ============================================================================
#  Clock Definition
# ============================================================================
# {{clock_freq_mhz}} MHz system clock
# Update the port name and pin to match your board's clock input.
create_clock -period {{ (1000.0 / clock_freq_mhz) | round(3) }} -name sys_clk [get_ports CLK]

# If your board has a differential clock:
# create_clock -period 10.000 -name sys_clk [get_ports sys_clk_p]
# set_property IOSTANDARD DIFF_SSTL15 [get_ports {sys_clk_p sys_clk_n}]

# ============================================================================
#  Clock Port Pin Assignment
# ============================================================================
# Example: Arty A7 has a 100 MHz clock on pin E3
# set_property -dict {PACKAGE_PIN E3 IOSTANDARD LVCMOS33} [get_ports CLK]

# ============================================================================
#  Reset Pin
# ============================================================================
# Active-low reset — update pin for your board
# set_property -dict {PACKAGE_PIN C2 IOSTANDARD LVCMOS33} [get_ports RST_N]
set_false_path -from [get_ports RST_N]

# ============================================================================
#  I/O Standard Defaults
# ============================================================================
# Set default I/O standard for all ports. Override per-pin as needed.
# set_property IOSTANDARD LVCMOS33 [get_ports *]

# ============================================================================
#  AXI / Data Bus Pins
# ============================================================================
# Uncomment and map the AXI interface signals to physical pins.
# Typical signals for an AXI4-Lite slave:
#
# set_property -dict {PACKAGE_PIN <pin> IOSTANDARD LVCMOS33} [get_ports {axi_awaddr[0]}]
# set_property -dict {PACKAGE_PIN <pin> IOSTANDARD LVCMOS33} [get_ports {axi_awaddr[1]}]
# ... (repeat for all address/data/control bits)

# ============================================================================
#  LED / Debug Outputs (useful for prototyping)
# ============================================================================
# Example: Arty A7 LEDs
# set_property -dict {PACKAGE_PIN H5  IOSTANDARD LVCMOS33} [get_ports {led[0]}]
# set_property -dict {PACKAGE_PIN J5  IOSTANDARD LVCMOS33} [get_ports {led[1]}]
# set_property -dict {PACKAGE_PIN T9  IOSTANDARD LVCMOS33} [get_ports {led[2]}]
# set_property -dict {PACKAGE_PIN T10 IOSTANDARD LVCMOS33} [get_ports {led[3]}]

# ============================================================================
#  Button / Switch Inputs
# ============================================================================
# set_property -dict {PACKAGE_PIN D9  IOSTANDARD LVCMOS33} [get_ports {btn[0]}]
# set_property -dict {PACKAGE_PIN C9  IOSTANDARD LVCMOS33} [get_ports {btn[1]}]

# ============================================================================
#  Timing Exceptions
# ============================================================================
# Use set_false_path for asynchronous signals (buttons, switches, LEDs).
# set_false_path -to [get_ports {led[*]}]
# set_false_path -from [get_ports {btn[*]}]

# ============================================================================
#  Bitstream Configuration
# ============================================================================
# SPI flash programming options (adjust for your board)
# set_property BITSTREAM.CONFIG.SPI_BUSWIDTH 4 [current_design]
# set_property CONFIG_MODE SPIx4 [current_design]
#
# NOTE: the three properties below are valid for 7-series parts (the default
# {{fpga_part}}). On UltraScale/UltraScale+ devices CONFIG_VOLTAGE/CFGBVS are
# either different or unsupported and Vivado will error — remove or adjust
# them when you change FPGA_PART.
set_property BITSTREAM.CONFIG.CONFIGRATE 33 [current_design]
set_property CONFIG_VOLTAGE 3.3 [current_design]
set_property CFGBVS VCCO [current_design]
