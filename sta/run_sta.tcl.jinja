# ==============================================================================
# OpenSTA timing analysis script for {{ip_name}}
# Generated by Copier template
#
# Settings come from environment variables exported by sta/Makefile:
#   TOP_MODULE, NETLIST, SDC_FILE, LIB_FILE, REPORT_DIR
#   STA_MODE = all | setup | hold  (selects which checks to report)
# ==============================================================================

set top_module  $::env(TOP_MODULE)
set netlist     $::env(NETLIST)
set sdc_file    $::env(SDC_FILE)
set lib_file    $::env(LIB_FILE)
set report_dir  $::env(REPORT_DIR)
set mode        [expr {[info exists ::env(STA_MODE)] ? $::env(STA_MODE) : "all"}]

file mkdir $report_dir

# --- Read liberty timing library -------------------------------------------
puts "\n>>> Reading liberty: $lib_file"
read_liberty $lib_file

# --- Read synthesized Verilog netlist --------------------------------------
puts "\n>>> Reading netlist: $netlist"
read_verilog $netlist

# --- Link design -----------------------------------------------------------
puts "\n>>> Linking design: $top_module"
link_design $top_module

# --- Read SDC constraints --------------------------------------------------
puts "\n>>> Reading SDC: $sdc_file"
read_sdc $sdc_file

# --- Setup (max-path) checks -----------------------------------------------
if {$mode eq "all" || $mode eq "setup"} {
    puts "\n>>> Reporting setup checks"
    report_checks -path_delay max -fields {slew cap input_pins nets} \
        -format full_clock_expanded \
        > $report_dir/${top_module}_setup.rpt
}

# --- Hold (min-path) checks --------------------------------------------------
if {$mode eq "all" || $mode eq "hold"} {
    puts "\n>>> Reporting hold checks"
    report_checks -path_delay min -fields {slew cap input_pins nets} \
        -format full_clock_expanded \
        > $report_dir/${top_module}_hold.rpt
}

if {$mode eq "all"} {
    # --- Clock properties ----------------------------------------------------
    puts "\n>>> Reporting clocks"
    report_clock_properties > $report_dir/${top_module}_clocks.rpt

    # --- Timing summary ------------------------------------------------------
    puts "\n>>> Reporting timing summary"
    report_tns > $report_dir/${top_module}_tns.rpt
    report_wns > $report_dir/${top_module}_wns.rpt
}

puts "\n>>> STA ($mode) complete. Reports written to $report_dir/"
exit
