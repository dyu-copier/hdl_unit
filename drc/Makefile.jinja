	#   -input2 $(VERILOG_GL) \
	#   -output $(REPORTS_DIR)/calibre_lvs.rpt

# ============================================================================
#  Clean
# ============================================================================

clean:
	rm -rf $(REPORTS_DIR)
	@echo "[drc] Clean complete."
