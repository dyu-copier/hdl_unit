calibre_drc: folders
	@echo "[drc] Calibre DRC — not yet configured"
	@echo "TODO: Set DRC_RULES to point to your PDK rule deck"
	# $(CALIBRE_DRC) -batch \
	#   -hier \
	#   $(DRC_RULES) \
	#   -input $(GDS_FILE) \
	#   -output $(REPORTS_DIR)/calibre_drc.rpt

