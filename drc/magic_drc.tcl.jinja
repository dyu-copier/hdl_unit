# ============================================================================
# Magic DRC Script — {{ip_name}}
# Author: {{author}} <{{email}}>
# Description: Run Design Rule Checks on {{ip_name|capitalize}} layout using Magic
#
# Usage (via drc/Makefile):
#   GDS_FILE=<gds> REPORTS_DIR=<dir> magic -dnull -noconsole -T <techfile> magic_drc.tcl
#
# The Magic technology file is passed with -T on the command line.
# The script exits non-zero when violations are found so `make drc` fails.
# ============================================================================

# ── Configuration ───────────────────────────────────────────────────────────
if {[info exists ::env(GDS_FILE)]} {
    set gds_file $::env(GDS_FILE)
} else {
    # LibreLane writes GDS to pnr/runs/<tag>/final/gds/; pick the latest run.
    set candidates [lsort [glob -nocomplain "../pnr/runs/*/final/gds/mk{{ip_name|capitalize}}.gds"]]
    if {[llength $candidates] == 0} {
        puts "ERROR: no GDS found under ../pnr/runs/. Run 'make -C ../pnr pnr' first."
        exit 1
    }
    set gds_file [lindex $candidates end]
}

if {[info exists ::env(REPORTS_DIR)]} {
    set reports_dir $::env(REPORTS_DIR)
} else {
    set reports_dir "reports"
}

set top_cell "mk{{ip_name|capitalize}}"
set drc_report "${reports_dir}/magic_drc.rpt"

puts "============================================================"
puts "  {{ip_name|capitalize}} — Magic DRC"
puts "  GDS file:    $gds_file"
puts "  Top cell:    $top_cell"
puts "  Report:      $drc_report"
puts "============================================================"

file mkdir $reports_dir

# ── Load GDS ────────────────────────────────────────────────────────────────
puts "\n>>> Loading GDS: $gds_file"
gds read $gds_file

puts ">>> Loading top cell: $top_cell"
load $top_cell
select top cell
expand

# ── Run DRC ─────────────────────────────────────────────────────────────────
puts "\n>>> Running DRC..."
drc euclidean on
drc style drc(full)
drc catchup
drc check

# Total violation count — `drc list count total` is the stable interface.
set total_errors [drc list count total]

# ── Write report ────────────────────────────────────────────────────────────
set rpt [open $drc_report w]
puts $rpt "============================================================"
puts $rpt "  Magic DRC Report — {{ip_name|capitalize}}"
puts $rpt "  GDS:  $gds_file"
puts $rpt "  Cell: $top_cell"
puts $rpt "  Date: {% raw %}[clock format [clock seconds] -format {%Y-%m-%d %H:%M:%S}]{% endraw %}"
puts $rpt "============================================================"
puts $rpt ""

if {$total_errors == 0} {
    puts $rpt "No DRC violations found. Design is clean."
} else {
    # `drc listall why` returns one entry per violated rule description;
    # dump each entry verbatim rather than assuming a {rule count} pairing.
    puts $rpt "Violated rules:"
    foreach why [drc listall why] {
        puts $rpt "  - $why"
    }
    puts $rpt ""
    puts $rpt "Total DRC violation count: $total_errors"
}

puts $rpt ""
puts $rpt "============================================================"
puts $rpt "  End of report"
puts $rpt "============================================================"
close $rpt

puts ">>> Report written to: $drc_report"

# ── Summary to stdout ───────────────────────────────────────────────────────
puts "\n============================================================"
if {$total_errors == 0} {
    puts "  RESULT: DRC CLEAN"
} else {
    puts "  RESULT: $total_errors DRC ERROR(s)"
}
puts "  Report: $drc_report"
puts "============================================================"

# ── Exit (non-zero on violations so `make drc` fails) ──────────────────────
if {$total_errors > 0} {
    quit -noprompt 1
}
quit -noprompt
