# ==============================================================================
# OpenROAD place-and-route flow for {{ip_name}}
# Generated by Copier template
#
# Settings come from environment variables exported by pnr/Makefile:
#   TOP_MODULE, NETLIST, SDC_FILE, TECH_LEF, MACRO_LEF, LIB_FILE,
#   OUTPUT_DIR, REPORT_DIR
# PDK-specific cells/layers come from pnr/pdk_config.tcl.
#
# Scope: a trial-route quality flow for unit-level PPA exploration. It does
# not build a power grid (pdngen) or run antenna repair — those need a real
# floorplan/padring context. GDS export is a separate `make gds` step (Magic).
# ==============================================================================

set top_module  $::env(TOP_MODULE)
set netlist     $::env(NETLIST)
set sdc_file    $::env(SDC_FILE)
set tech_lef    $::env(TECH_LEF)
set macro_lef   $::env(MACRO_LEF)
set lib_file    $::env(LIB_FILE)
set output_dir  $::env(OUTPUT_DIR)
set report_dir  $::env(REPORT_DIR)

file mkdir $output_dir
file mkdir $report_dir

source pdk_config.tcl

# === 1. Read technology + library data ======================================
puts "\n>>> Reading technology LEF: $tech_lef"
read_lef $tech_lef

puts "\n>>> Reading macro LEF: $macro_lef"
read_lef $macro_lef

puts "\n>>> Reading liberty: $lib_file"
read_liberty $lib_file

# === 2. Read synthesized Verilog netlist ===================================
puts "\n>>> Reading netlist: $netlist"
read_verilog $netlist
link_design $top_module

# === 3. Read SDC constraints ===============================================
puts "\n>>> Reading SDC: $sdc_file"
read_sdc $sdc_file

# === 4. Initialize floorplan ===============================================
puts "\n>>> Initializing floorplan"
# Utilization 40%, aspect ratio 1.0, core margins 10 µm on each side
initialize_floorplan -utilization 40 \
    -aspect_ratio 1.0 \
    -core_space {10 10 10 10} \
    -site $PDK(site)

# Insert tap cells if the PDK defines one
if {$PDK(tapcell) ne ""} {
    puts "\n>>> Inserting tap cells"
    tapcell -distance 14 -tapcell_master $PDK(tapcell)
}

# === 5. Pin placement ======================================================
puts "\n>>> Placing IO pins"
place_pins -hor_layers $PDK(pin_hor_layer) -ver_layers $PDK(pin_ver_layer)

# === 6. Global placement ===================================================
puts "\n>>> Running global placement"
global_placement -density 0.6

# Fix drive/slew problems before CTS
puts "\n>>> Repairing design (buffering / resizing)"
estimate_parasitics -placement
repair_design

# === 7. Clock tree synthesis (TritonCTS) ===================================
puts "\n>>> Running clock tree synthesis"
clock_tree_synthesis -root_buf $PDK(cts_root_buf) \
    -buf_list $PDK(cts_buf_list)

# === 8. Detailed placement =================================================
puts "\n>>> Running detailed placement"
detailed_placement
check_placement

# === 9. Global routing =====================================================
puts "\n>>> Running global routing"
set_routing_layers -signal $PDK(min_route_layer)-$PDK(max_route_layer)
global_route -congestion_iterations 50

# === 10. Detailed routing ==================================================
puts "\n>>> Running detailed routing"
detailed_route -output_drc $report_dir/${top_module}_route_drc.rpt

# === 11. Filler insertion ==================================================
if {[llength $PDK(filler_cells)] > 0} {
    puts "\n>>> Inserting filler cells"
    filler_placement $PDK(filler_cells)
}

# === 12. Write outputs =====================================================
puts "\n>>> Writing final DEF"
write_def $output_dir/${top_module}_final.def

puts "\n>>> Writing routed netlist"
write_verilog $output_dir/${top_module}_routed.v

puts "\n>>> Writing OpenROAD database"
write_db $output_dir/${top_module}.odb

# === 13. Final reports =====================================================
puts "\n>>> Generating timing report"
estimate_parasitics -global_routing
report_checks -path_delay max \
    -fields {slew cap input_pins nets} \
    > $report_dir/${top_module}_timing.rpt

puts "\n>>> Generating power report"
report_power > $report_dir/${top_module}_power.rpt

puts "\n>>> Generating area report"
report_design_area > $report_dir/${top_module}_area.rpt

puts "\n>>> PnR flow complete. Outputs in $output_dir/, reports in $report_dir/"
puts ">>> Run 'make gds' to export GDS (input for drc/)."
exit
