# ============================================================================
# Makefile for Clock Domain Crossing (CDC) Analysis — {{ip_name}}
# {{ip_short_desc}}
#
# Open-source approach:
#   yosys_cdc  — Yosys-based CDC check using cdc_check.tcl
#
# Commercial stubs:
#   spyglass_cdc — Synopsys SpyGlass CDC (requires license)
#
# Author: {{author}} <{{email}}>
# ============================================================================
.ONESHELL:
SHELL := /bin/bash

# ---------------------------------------------------------------------------
# Paths & variables
# ---------------------------------------------------------------------------
VERILOG_DIR   := $({{ip_name|capitalize}}_ROOT)/verilog
TOP_MODULE    := mk{{ip_name|capitalize}}
TOP_FILE      := $(VERILOG_DIR)/$(TOP_MODULE).v
REPORT_DIR    := reports
CDC_SCRIPT    := cdc_check.tcl

# Collect all Verilog sources
VLOG_SRCS     := $(wildcard $(VERILOG_DIR)/*.v)

# ---------------------------------------------------------------------------
# Default target
# ---------------------------------------------------------------------------
all: yosys_cdc

# ---------------------------------------------------------------------------
# Create report directory
# ---------------------------------------------------------------------------
$(REPORT_DIR):
	mkdir -p $(REPORT_DIR)

# ---------------------------------------------------------------------------
# Yosys-based CDC check (open-source)
#
# Uses Yosys to elaborate the design and a custom Tcl script to identify
# signals that cross clock domain boundaries. This is a best-effort
# structural analysis — it does NOT replace a full CDC verification tool
# but catches common issues early.
# ---------------------------------------------------------------------------
.PHONY: yosys_cdc
yosys_cdc: $(REPORT_DIR)
	@echo "=== Yosys CDC Check: $(TOP_MODULE) ==="
	YOSYS_TOP=$(TOP_MODULE) \
	YOSYS_VLOG_DIR=$(VERILOG_DIR) \
	YOSYS_REPORT_DIR=$(REPORT_DIR) \
	yosys -c $(CDC_SCRIPT) \
		2>&1 | tee $(REPORT_DIR)/yosys_cdc.log
	@echo "Report: $(REPORT_DIR)/cdc_report.txt"

# ---------------------------------------------------------------------------
# Synopsys SpyGlass CDC (commercial — stub)
# ---------------------------------------------------------------------------
.PHONY: spyglass_cdc
spyglass_cdc: $(REPORT_DIR)
	@echo "=== SpyGlass CDC Analysis: $(TOP_MODULE) ==="
	@echo "NOTE: SpyGlass CDC requires a commercial license."
	@echo "Configure SPYGLASS_HOME and update this target for your environment."
	# sg_shell -tcl_file spyglass_cdc.tcl \
	#   -project $(TOP_MODULE)_cdc \
	#   2>&1 | tee $(REPORT_DIR)/spyglass_cdc.rpt
	@echo "SpyGlass CDC target is a stub — edit cdc/Makefile to enable."

# ---------------------------------------------------------------------------
# Clean
# ---------------------------------------------------------------------------
.PHONY: clean
clean:
	rm -rf $(REPORT_DIR)

.PHONY: help
help:
	@echo "CDC targets for {{ip_name}}:"
	@echo "  make              — run Yosys CDC check (default)"
	@echo "  make yosys_cdc    — Yosys + Tcl-based CDC analysis"
	@echo "  make spyglass_cdc — SpyGlass CDC (stub)"
	@echo "  make clean        — remove reports"
