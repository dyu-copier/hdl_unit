# ============================================================================
# cdc_check.tcl — Yosys elaboration stage of the CDC check for {{ip_name}}
# Invoke with `yosys -c` (Tcl mode); driven by cdc/Makefile.
#
# Stage 1 of 2: elaborate + flatten the design, keep flip-flops as generic
# $dff/$sdff/$adff cells, and dump a JSON netlist. Stage 2
# (scripts/cdc_report.py) does the actual clock-domain grouping and
# crossing detection on the JSON.
#
# Environment variables (set by Makefile):
#   YOSYS_TOP       — top module name
#   YOSYS_VLOG_DIR  — path to Verilog sources
#   YOSYS_JSON      — output JSON netlist path
#   BLUESPEC_HOME   — bsc installation (primitive library search path)
# ============================================================================

yosys -import

set top_module $::env(YOSYS_TOP)
set vlog_dir   $::env(YOSYS_VLOG_DIR)
set json_out   $::env(YOSYS_JSON)
set bsv_lib    $::env(BLUESPEC_HOME)/lib/Verilog

puts "\n=== CDC elaboration: $top_module ==="
puts "Verilog dir : $vlog_dir"
puts "JSON output : $json_out\n"

# 1. Read design sources, excluding BRAM primitives (they use sim constructs
#    Yosys cannot parse in synthesis mode); resolve any remaining Bluespec
#    primitives from the bsc installation on demand.
foreach vfile [glob -nocomplain $vlog_dir/*.v] {
    if {![string match */BRAM*.v $vfile]} {
        puts "Reading: $vfile"
        yosys read_verilog -sv $vfile
    }
}
yosys hierarchy -check -top $top_module -libdir $bsv_lib

# 2. Elaborate processes to netlist form and flatten so every flop is
#    visible at the top level with its real clock net.
yosys proc
yosys flatten
yosys opt_clean

# 3. Keep flops as generic $dff-family cells (no techmap/abc — that would
#    obscure clock pins). Design stats for the log:
yosys stat

# 4. Dump the netlist for the Python analysis stage.
yosys write_json $json_out

puts "\n=== JSON netlist written to $json_out ==="
