name: {{ip_name}} CI

# Tests the actual {{ip_name}} IP's RTL, RDL, and cocotb tests against the
# pre-built rtl_unit_tools docker image. Runs `make ci_full`, which chains
# lint -> formal -> test (cocotb) -> synth -> sta -> pnr -> drc -> power.

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

# GITHUB_TOKEN least privilege: checkout only (the tools image is public).
permissions:
  contents: read

# Supersede in-flight runs of the same PR/branch; never cancel main builds.
concurrency:
  group: {% raw %}${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: {% raw %}${{ github.event_name == 'pull_request' }}{% endraw %}

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 120
    steps:
      - name: Checkout {{ip_name}}
        uses: actions/checkout@v6
        with:
          path: {{ip_name}}

      - name: Checkout bsv_axi
        uses: actions/checkout@v6
        with:
          repository: dyumnin/bsv_bus_protocols
          path: bsv_axi

      - name: Purge stale .bo files in bsv_axi (BSC version mismatch guard)
        run: find bsv_axi -name '*.bo' -delete 2>/dev/null || true

      - name: Pull rtl_unit_tools docker image
        run: docker pull ghcr.io/dyu-copier/rtl_unit_tools:latest

      - name: Run ci_full on the {{ip_name}} sources
        run: |
          docker run --rm \
            -v {% raw %}${{ github.workspace }}{% endraw %}/bsv_axi:/bsv_axi:ro \
            -v {% raw %}${{ github.workspace }}{% endraw %}/{{ip_name}}:/tmp/{{ip_name}} \
            -e {{ip_name|upper}}_ROOT=/tmp/{{ip_name}} \
            -e BSC_PATH=".:/bsv_axi/src/axi4:/bsv_axi/src/apb:/bsv_axi/src/common:+" \
            -e PDK_ROOT=/opt/pdk \
            -w /tmp/{{ip_name}} \
            ghcr.io/dyu-copier/rtl_unit_tools:latest \
            make ci_full

      - name: Upload build artifacts on failure
        if: failure()
        uses: actions/upload-artifact@v7
        with:
          name: {{ip_name}}-ci-artifacts
          path: |
            {{ip_name}}/verilog/
            {{ip_name}}/synth/output/
            {{ip_name}}/synth/reports/
            {{ip_name}}/sta/reports/
            {{ip_name}}/power/reports/
            {{ip_name}}/pnr/runs/
            {{ip_name}}/drc/reports/
            {{ip_name}}/tb/*.vcd
            {{ip_name}}/tb/results.xml
          if-no-files-found: ignore
