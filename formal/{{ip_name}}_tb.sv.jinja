// Formal verification testbench for mk{{ip_name|capitalize}}
//
// Protocol checkers: ZipCPU wb2axip fapb_slave (APB) + our own
// axi4_slave_checker / axi4_master_checker (AXI4) — see
// formal/checkers/axi4_slave_checker.v and axi4_master_checker.v.
// fapb_slave license: Apache 2.0 (commercial closed-source use permitted;
//                      retain the copyright notice in the downloaded file).
//
// Top-level inputs are free variables: sby/smtbmc explores all
// valid combinations constrained by the protocol checkers.
//
// APB is always a slave (config/CSR bus, project convention, never
// initiates a transaction). The AXI4 data bus is independently
// configurable per the has_axi_slave/has_axi_master copier answers: a
// slave interface (axi4_s, DUT receives requests), a master interface
// (axi4_m, DUT initiates requests), both, or neither.
//
//   fapb_slave         — assumes APB master stimulus follows APB protocol;
//                         asserts DUT APB slave response is compliant.
{%- if has_axi_slave %}
//   axi4_slave_checker — assumes AXI4 master stimulus follows AXI4 protocol;
//                         asserts DUT AXI4 slave response is compliant.
{%- endif %}
{%- if has_axi_master %}
//   axi4_master_checker — asserts DUT AXI4 master stimulus follows AXI4
//                          protocol; assumes AXI4 slave response is
//                          compliant.
{%- endif %}
//
// Author: {{author}} <{{email}}>
`default_nettype none

module tb_mk{{ip_name|capitalize}} (
    input wire clk,
    input wire rst_n,

    // ---- APB master stimulus (free variables) ----
    input wire        apb_PSEL,
    input wire        apb_PENABLE,
    input wire [31:0] apb_PADDR,
    input wire        apb_PWRITE,
    input wire [31:0] apb_PWDATA,
    input wire [3:0]  apb_PSTRB,
    input wire [2:0]  apb_PROT{% if has_axi_slave or has_axi_master %},{% endif %}
{% if has_axi_slave -%}
    // ---- AXI4 slave: master stimulus (free variables) ----
    input wire        axi4_s_awvalid,
    input wire [3:0]  axi4_s_awid,
    input wire [31:0] axi4_s_awaddr,
    input wire [7:0]  axi4_s_awlen,
    input wire [2:0]  axi4_s_awsize,
    input wire [1:0]  axi4_s_awburst,
    input wire        axi4_s_awlock,
    input wire [3:0]  axi4_s_awcache,
    input wire [2:0]  axi4_s_awprot,
    input wire [3:0]  axi4_s_awqos,
    input wire [3:0]  axi4_s_awregion,

    input wire        axi4_s_wvalid,
    input wire [31:0] axi4_s_wdata,
    input wire [3:0]  axi4_s_wstrb,
    input wire        axi4_s_wlast,

    input wire        axi4_s_bready,

    input wire        axi4_s_arvalid,
    input wire [3:0]  axi4_s_arid,
    input wire [31:0] axi4_s_araddr,
    input wire [7:0]  axi4_s_arlen,
    input wire [2:0]  axi4_s_arsize,
    input wire [1:0]  axi4_s_arburst,
    input wire        axi4_s_arlock,
    input wire [3:0]  axi4_s_arcache,
    input wire [2:0]  axi4_s_arprot,
    input wire [3:0]  axi4_s_arqos,
    input wire [3:0]  axi4_s_arregion,

    input wire        axi4_s_rready{% if has_axi_master %},{% endif %}
{% endif -%}
{% if has_axi_master -%}
    // ---- AXI4 master: slave stimulus (free variables) ----
    input wire        axi4_m_awready,
    input wire        axi4_m_wready,
    input wire        axi4_m_bvalid,
    input wire [3:0]  axi4_m_bid,
    input wire [1:0]  axi4_m_bresp,
    input wire        axi4_m_arready,
    input wire        axi4_m_rvalid,
    input wire [3:0]  axi4_m_rid,
    input wire [31:0] axi4_m_rdata,
    input wire        axi4_m_rlast,
    input wire [1:0]  axi4_m_rresp
{% endif -%}
);
{% if has_axi_slave %}
    // ---------------------------------------------------------------
    // Wires for DUT AXI4 slave outputs
    // ---------------------------------------------------------------
    wire        axi4_s_awready;
    wire        axi4_s_wready;
    wire        axi4_s_bvalid;
    wire [3:0]  axi4_s_bid;
    wire [1:0]  axi4_s_bresp;
    wire        axi4_s_arready;
    wire        axi4_s_rvalid;
    wire [3:0]  axi4_s_rid;
    wire [31:0] axi4_s_rdata;
    wire        axi4_s_rlast;
    wire [1:0]  axi4_s_rresp;
{% endif -%}
{% if has_axi_master %}
    // ---------------------------------------------------------------
    // Wires for DUT AXI4 master outputs
    // ---------------------------------------------------------------
    wire        axi4_m_awvalid;
    wire [3:0]  axi4_m_awid;
    wire [31:0] axi4_m_awaddr;
    wire [7:0]  axi4_m_awlen;
    wire [2:0]  axi4_m_awsize;
    wire [1:0]  axi4_m_awburst;
    wire        axi4_m_awlock;
    wire [3:0]  axi4_m_awcache;
    wire [2:0]  axi4_m_awprot;
    wire [3:0]  axi4_m_awqos;
    wire [3:0]  axi4_m_awregion;

    wire        axi4_m_wvalid;
    wire [31:0] axi4_m_wdata;
    wire [3:0]  axi4_m_wstrb;
    wire        axi4_m_wlast;

    wire        axi4_m_bready;

    wire        axi4_m_arvalid;
    wire [3:0]  axi4_m_arid;
    wire [31:0] axi4_m_araddr;
    wire [7:0]  axi4_m_arlen;
    wire [2:0]  axi4_m_arsize;
    wire [1:0]  axi4_m_arburst;
    wire        axi4_m_arlock;
    wire [3:0]  axi4_m_arcache;
    wire [2:0]  axi4_m_arprot;
    wire [3:0]  axi4_m_arqos;
    wire [3:0]  axi4_m_arregion;

    wire        axi4_m_rready;
{% endif %}
    // ---------------------------------------------------------------
    // Wires for DUT APB slave outputs
    // ---------------------------------------------------------------
    wire        apb_PREADY;
    wire [31:0] apb_PRDATA;
    wire        apb_PSLVERR;

    // ---------------------------------------------------------------
    // DUT instantiation
    //
    // BSC compiles APB port names UPPERCASE (from port= attributes in
    // APB_Types.bsv) and AXI4 port names lowercase (from result=/port=
    // attributes in AXI4_Types.bsv). ID_WIDTH=4 so BSC includes
    // awid/bid/arid/rid; USER_WIDTH=0 so *user ports are omitted.
    // ---------------------------------------------------------------
    mk{{ip_name|capitalize}} dut (
        .CLK           (clk),
        .RST_N         (rst_n),
        // APB slave inputs
        .apb_PSEL      (apb_PSEL),
        .apb_PENABLE   (apb_PENABLE),
        .apb_PADDR     (apb_PADDR),
        .apb_PWRITE    (apb_PWRITE),
        .apb_PWDATA    (apb_PWDATA),
        .apb_PSTRB     (apb_PSTRB),
        .apb_PPROT     (apb_PROT),
        // APB slave outputs
        .apb_PREADY    (apb_PREADY),
        .apb_PRDATA    (apb_PRDATA),
        .apb_PSLVERR   (apb_PSLVERR){% if has_axi_slave %},
        // AXI4 slave inputs (master stimulus)
        .axi4_s_awvalid  (axi4_s_awvalid),
        .axi4_s_awid     (axi4_s_awid),
        .axi4_s_awaddr   (axi4_s_awaddr),
        .axi4_s_awlen    (axi4_s_awlen),
        .axi4_s_awsize   (axi4_s_awsize),
        .axi4_s_awburst  (axi4_s_awburst),
        .axi4_s_awlock   (axi4_s_awlock),
        .axi4_s_awcache  (axi4_s_awcache),
        .axi4_s_awprot   (axi4_s_awprot),
        .axi4_s_awqos    (axi4_s_awqos),
        .axi4_s_awregion (axi4_s_awregion),
        .axi4_s_wvalid   (axi4_s_wvalid),
        .axi4_s_wdata    (axi4_s_wdata),
        .axi4_s_wstrb    (axi4_s_wstrb),
        .axi4_s_wlast    (axi4_s_wlast),
        .axi4_s_bready   (axi4_s_bready),
        .axi4_s_arvalid  (axi4_s_arvalid),
        .axi4_s_arid     (axi4_s_arid),
        .axi4_s_araddr   (axi4_s_araddr),
        .axi4_s_arlen    (axi4_s_arlen),
        .axi4_s_arsize   (axi4_s_arsize),
        .axi4_s_arburst  (axi4_s_arburst),
        .axi4_s_arlock   (axi4_s_arlock),
        .axi4_s_arcache  (axi4_s_arcache),
        .axi4_s_arprot   (axi4_s_arprot),
        .axi4_s_arqos    (axi4_s_arqos),
        .axi4_s_arregion (axi4_s_arregion),
        .axi4_s_rready   (axi4_s_rready),
        // AXI4 slave outputs
        .axi4_s_awready  (axi4_s_awready),
        .axi4_s_wready   (axi4_s_wready),
        .axi4_s_bvalid   (axi4_s_bvalid),
        .axi4_s_bid      (axi4_s_bid),
        .axi4_s_bresp    (axi4_s_bresp),
        .axi4_s_arready  (axi4_s_arready),
        .axi4_s_rvalid   (axi4_s_rvalid),
        .axi4_s_rid      (axi4_s_rid),
        .axi4_s_rdata    (axi4_s_rdata),
        .axi4_s_rlast    (axi4_s_rlast),
        .axi4_s_rresp    (axi4_s_rresp){% endif %}{% if has_axi_master %},
        // AXI4 master outputs
        .axi4_m_awvalid  (axi4_m_awvalid),
        .axi4_m_awid     (axi4_m_awid),
        .axi4_m_awaddr   (axi4_m_awaddr),
        .axi4_m_awlen    (axi4_m_awlen),
        .axi4_m_awsize   (axi4_m_awsize),
        .axi4_m_awburst  (axi4_m_awburst),
        .axi4_m_awlock   (axi4_m_awlock),
        .axi4_m_awcache  (axi4_m_awcache),
        .axi4_m_awprot   (axi4_m_awprot),
        .axi4_m_awqos    (axi4_m_awqos),
        .axi4_m_awregion (axi4_m_awregion),
        .axi4_m_wvalid   (axi4_m_wvalid),
        .axi4_m_wdata    (axi4_m_wdata),
        .axi4_m_wstrb    (axi4_m_wstrb),
        .axi4_m_wlast    (axi4_m_wlast),
        .axi4_m_bready   (axi4_m_bready),
        .axi4_m_arvalid  (axi4_m_arvalid),
        .axi4_m_arid     (axi4_m_arid),
        .axi4_m_araddr   (axi4_m_araddr),
        .axi4_m_arlen    (axi4_m_arlen),
        .axi4_m_arsize   (axi4_m_arsize),
        .axi4_m_arburst  (axi4_m_arburst),
        .axi4_m_arlock   (axi4_m_arlock),
        .axi4_m_arcache  (axi4_m_arcache),
        .axi4_m_arprot   (axi4_m_arprot),
        .axi4_m_arqos    (axi4_m_arqos),
        .axi4_m_arregion (axi4_m_arregion),
        .axi4_m_rready   (axi4_m_rready),
        // AXI4 master inputs (slave stimulus)
        .axi4_m_awready  (axi4_m_awready),
        .axi4_m_wready   (axi4_m_wready),
        .axi4_m_bvalid   (axi4_m_bvalid),
        .axi4_m_bid      (axi4_m_bid),
        .axi4_m_bresp    (axi4_m_bresp),
        .axi4_m_arready  (axi4_m_arready),
        .axi4_m_rvalid   (axi4_m_rvalid),
        .axi4_m_rid      (axi4_m_rid),
        .axi4_m_rdata    (axi4_m_rdata),
        .axi4_m_rlast    (axi4_m_rlast),
        .axi4_m_rresp    (axi4_m_rresp){% endif %}
    );

    // ---------------------------------------------------------------
    // Reset constraint: hold reset low for the first 4 cycles.
    // Counter is independent of rst_n so it advances unconditionally,
    // ensuring the constraint fires exactly at startup in both BMC and
    // the induction base case.
    // ---------------------------------------------------------------
    reg [3:0] f_cycle;
    initial   f_cycle = 4'h0;
    always @(posedge clk)
        if (f_cycle != 4'hf)
            f_cycle <= f_cycle + 4'h1;

    always @(*)
        if (f_cycle < 4'h4)
            assume(rst_n == 1'b0);

    // ---------------------------------------------------------------
    // APB slave protocol checker
    // (ZipCPU wb2axip/bench/formal/fapb_slave.v, Apache 2.0)
    //
    // Note: BSC also names this port PPROT (matches fapb_slave) — the DUT
    //       instantiation below connects .apb_PPROT, not .apb_PROT.
    //       BSC uses port name PSTRB; fapb_slave uses PWSTRB.
    //
    // F_OPT_INITIAL=0: the default (1) asserts PREADY/PSEL/PENABLE are low
    // in the power-up state *before any reset edge* — an FPGA-style
    // initial-value guarantee BSC-generated designs don't make (they rely
    // on RST_N, which the reset constraint above holds low for 4 cycles).
    // With 0 the checker verifies reset-phase and steady-state behavior
    // only, which is the correct contract for this design style.
    // ---------------------------------------------------------------
    fapb_slave #(
        .AW            (32),
        .DW            (32),
        .F_OPT_SLVERR  (1'b0),
        .F_OPT_INITIAL (1'b0)
    ) u_apb_chk (
        .PCLK    (clk),
        .PRESETn (rst_n),
        .PSEL    (apb_PSEL),
        .PENABLE (apb_PENABLE),
        .PADDR   (apb_PADDR),
        .PWRITE  (apb_PWRITE),
        .PWDATA  (apb_PWDATA),
        .PWSTRB  (apb_PSTRB),
        .PPROT   (apb_PROT),
        .PREADY  (apb_PREADY),
        .PRDATA  (apb_PRDATA),
        .PSLVERR (apb_PSLVERR)
    );
{% if has_axi_slave %}
    // ---------------------------------------------------------------
    // DUT contract: the generated stub is a single-beat CSR-style port —
    // it responds to every burst with one beat. Constrain the stimulus to
    // single-beat INCR bursts so the checker's burst rules (W1/RD1) match
    // the contract. REMOVE these assumes when the IP implements bursts.
    // ---------------------------------------------------------------
    always @(*) begin
        assume (axi4_s_awlen == 8'h00);
        assume (axi4_s_arlen == 8'h00);
        assume (axi4_s_awburst == 2'b01);
        assume (axi4_s_arburst == 2'b01);
    end

    // ---------------------------------------------------------------
    // AXI4 slave protocol checker (our own — full rule set shared with
    // the master checker via formal/checkers/axi4_checker_rules.vh;
    // rule IDs in AXI4_rules.md)
    // ---------------------------------------------------------------
    axi4_slave_checker #(
        .C_AXI_ID_WIDTH    (4),
        .C_AXI_ADDR_WIDTH  (32),
        .C_AXI_DATA_WIDTH  (32),
        .F_MAX_OUTSTANDING (4),
        .F_MAX_PER_ID      (2),
        .F_OPT_EXCLUSIVE   (0),
        .F_OPT_MAX_STALL   (0)
    ) u_axi_s_chk (
        .i_clk          (clk),
        .i_axi_reset_n  (rst_n),
        // Write address channel
        .i_axi_awvalid  (axi4_s_awvalid),
        .i_axi_awready  (axi4_s_awready),
        .i_axi_awid     (axi4_s_awid),
        .i_axi_awaddr   (axi4_s_awaddr),
        .i_axi_awlen    (axi4_s_awlen),
        .i_axi_awsize   (axi4_s_awsize),
        .i_axi_awburst  (axi4_s_awburst),
        .i_axi_awlock   (axi4_s_awlock),
        .i_axi_awcache  (axi4_s_awcache),
        .i_axi_awprot   (axi4_s_awprot),
        .i_axi_awqos    (axi4_s_awqos),
        .i_axi_awregion (axi4_s_awregion),
        // Write data channel
        .i_axi_wvalid   (axi4_s_wvalid),
        .i_axi_wready   (axi4_s_wready),
        .i_axi_wdata    (axi4_s_wdata),
        .i_axi_wstrb    (axi4_s_wstrb),
        .i_axi_wlast    (axi4_s_wlast),
        // Write response channel
        .i_axi_bvalid   (axi4_s_bvalid),
        .i_axi_bready   (axi4_s_bready),
        .i_axi_bid      (axi4_s_bid),
        .i_axi_bresp    (axi4_s_bresp),
        // Read address channel
        .i_axi_arvalid  (axi4_s_arvalid),
        .i_axi_arready  (axi4_s_arready),
        .i_axi_arid     (axi4_s_arid),
        .i_axi_araddr   (axi4_s_araddr),
        .i_axi_arlen    (axi4_s_arlen),
        .i_axi_arsize   (axi4_s_arsize),
        .i_axi_arburst  (axi4_s_arburst),
        .i_axi_arlock   (axi4_s_arlock),
        .i_axi_arcache  (axi4_s_arcache),
        .i_axi_arprot   (axi4_s_arprot),
        .i_axi_arqos    (axi4_s_arqos),
        .i_axi_arregion (axi4_s_arregion),
        // Read data channel
        .i_axi_rvalid   (axi4_s_rvalid),
        .i_axi_rready   (axi4_s_rready),
        .i_axi_rid      (axi4_s_rid),
        .i_axi_rdata    (axi4_s_rdata),
        .i_axi_rresp    (axi4_s_rresp),
        .i_axi_rlast    (axi4_s_rlast)
    );
{% endif -%}
{% if has_axi_master %}
    // ---------------------------------------------------------------
    // AXI4 master protocol checker (our own — full rule set shared with
    // the slave checker via formal/checkers/axi4_checker_rules.vh;
    // rule IDs in AXI4_rules.md). Capacity parameters become ASSERTS on
    // the DUT master here — raise them if the IP pipelines deeper.
    // ---------------------------------------------------------------
    axi4_master_checker #(
        .C_AXI_ID_WIDTH    (4),
        .C_AXI_ADDR_WIDTH  (32),
        .C_AXI_DATA_WIDTH  (32),
        .F_MAX_OUTSTANDING (4),
        .F_MAX_PER_ID      (2),
        .F_OPT_EXCLUSIVE   (0),
        .F_OPT_MAX_STALL   (0)
    ) u_axi_m_chk (
        .i_clk          (clk),
        .i_axi_reset_n  (rst_n),
        // Write address channel
        .i_axi_awvalid  (axi4_m_awvalid),
        .i_axi_awready  (axi4_m_awready),
        .i_axi_awid     (axi4_m_awid),
        .i_axi_awaddr   (axi4_m_awaddr),
        .i_axi_awlen    (axi4_m_awlen),
        .i_axi_awsize   (axi4_m_awsize),
        .i_axi_awburst  (axi4_m_awburst),
        .i_axi_awlock   (axi4_m_awlock),
        .i_axi_awcache  (axi4_m_awcache),
        .i_axi_awprot   (axi4_m_awprot),
        .i_axi_awqos    (axi4_m_awqos),
        .i_axi_awregion (axi4_m_awregion),
        // Write data channel
        .i_axi_wvalid   (axi4_m_wvalid),
        .i_axi_wready   (axi4_m_wready),
        .i_axi_wdata    (axi4_m_wdata),
        .i_axi_wstrb    (axi4_m_wstrb),
        .i_axi_wlast    (axi4_m_wlast),
        // Write response channel
        .i_axi_bvalid   (axi4_m_bvalid),
        .i_axi_bready   (axi4_m_bready),
        .i_axi_bid      (axi4_m_bid),
        .i_axi_bresp    (axi4_m_bresp),
        // Read address channel
        .i_axi_arvalid  (axi4_m_arvalid),
        .i_axi_arready  (axi4_m_arready),
        .i_axi_arid     (axi4_m_arid),
        .i_axi_araddr   (axi4_m_araddr),
        .i_axi_arlen    (axi4_m_arlen),
        .i_axi_arsize   (axi4_m_arsize),
        .i_axi_arburst  (axi4_m_arburst),
        .i_axi_arlock   (axi4_m_arlock),
        .i_axi_arcache  (axi4_m_arcache),
        .i_axi_arprot   (axi4_m_arprot),
        .i_axi_arqos    (axi4_m_arqos),
        .i_axi_arregion (axi4_m_arregion),
        // Read data channel
        .i_axi_rvalid   (axi4_m_rvalid),
        .i_axi_rready   (axi4_m_rready),
        .i_axi_rid      (axi4_m_rid),
        .i_axi_rdata    (axi4_m_rdata),
        .i_axi_rresp    (axi4_m_rresp),
        .i_axi_rlast    (axi4_m_rlast)
    );
{% endif %}
    // ---------------------------------------------------------------
    // Cover: reachability targets for sby cover mode
    // ---------------------------------------------------------------
    always @(posedge clk) begin
        cover (apb_PREADY && !apb_PSLVERR);
{%- if has_axi_slave %}
        cover (axi4_s_awvalid && axi4_s_awready);
        cover (axi4_s_arvalid && axi4_s_arready);
        cover (axi4_s_bvalid && axi4_s_bready);
        cover (axi4_s_rvalid && axi4_s_rready && axi4_s_rlast);
{%- endif %}
{%- if has_axi_master %}
        cover (axi4_m_awvalid && axi4_m_awready);
        cover (axi4_m_arvalid && axi4_m_arready);
        cover (axi4_m_bvalid && axi4_m_bready);
        cover (axi4_m_rvalid && axi4_m_rready && axi4_m_rlast);
{%- endif %}
    end

endmodule
`default_nettype wire
